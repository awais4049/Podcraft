rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt == request.time;
    }

    function isValidEpisode(data) {
      return data.keys().hasAll(['userId', 'niche', 'goal', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.niche is string && data.niche.size() <= 100 &&
             data.goal in ['Educational', 'Entertainment', 'Promotional'] &&
             data.createdAt == (resource == null ? request.time : resource.data.createdAt) &&
             data.updatedAt == request.time;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /episodes/{episodeId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(existing().userId);
      
      allow create: if isSignedIn() && isValidId(episodeId) && 
                    isValidEpisode(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(request.auth.uid));
      
      allow update: if isSignedIn() && isOwner(existing().userId) &&
                    isValidEpisode(incoming()) &&
                    (
                      // Action: Edit metadata
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'niche', 'goal', 'updatedAt']) ||
                      // Action: Save AI analysis
                      incoming().diff(existing()).affectedKeys().hasOnly(['data', 'status', 'updatedAt'])
                    );
      
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
